          <Avatar label="KW" size="xl" />
          <Text fontSize={10} color="$faint">sizes xs → xl</Text>
        </Stack>
        <Stack direction="horizontal" gap={16} align="center">
          <Avatar label="AB" size="lg" status="online" />
          <Avatar label="CD" size="lg" status="busy" />
          <Avatar label="EF" size="lg" status="away" />
          <Avatar label="GH" size="lg" status="offline" />
