      <Line color="$subtle" />
      <Stack gap={16} margin="4 0 0 0">
        <Stack direction="horizontal" gap={16} align="center">
          <Avatar label="KW" size="xs" />
          <Avatar label="KW" size="sm" />
          <Avatar label="KW" size="md" />
